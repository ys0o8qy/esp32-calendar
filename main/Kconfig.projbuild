menu "ESP32 Calendar"

config CALENDAR_WIFI_SSID
    string "Wi-Fi SSID"
    default ""
    help
        Wi-Fi network name used by the calendar firmware for SNTP time sync.
        Leave empty to skip Wi-Fi startup.

config CALENDAR_WIFI_PASSWORD
    string "Wi-Fi password"
    default ""
    help
        Wi-Fi password for CALENDAR_WIFI_SSID. Leave empty for open networks.

config CALENDAR_SNTP_SERVER
    string "SNTP server"
    default "ntp.aliyun.com"
    help
        SNTP server used to set system time and refresh the PCF85063 RTC.

config CALENDAR_DUMP_RLCD_FRAME
    bool "Dump the first RLCD frame to the serial log"
    default n
    help
        Emit the first ST7305 landscape 1bpp frame buffer as hex chunks.
        This is intended for render debugging only and should stay disabled
        during normal firmware runs.

endmenu
