CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# DFRobot K10: 16 MB QIO flash @ 80 MHz
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# DFRobot K10: 8 MB octal PSRAM @ 80 MHz
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y

# K10 audio output: internal/dummy codec over I2S TX (stereo on wire).
CONFIG_CODEC_DUMMY_SUPPORT=y

# K10 microphone: ES7243E on I2S0 STD RX (Philips stereo).
CONFIG_CODEC_ES7243E_SUPPORT=y

# K10 camera: GC2145 over DVP 8-bit
CONFIG_ESP_BOARD_DEV_CAMERA_SUPPORT=y
CONFIG_ESP_VIDEO_ENABLE_DVP_VIDEO_DEVICE=y
CONFIG_CAMERA_GC2145=y

# SCI Sensor
CONFIG_APP_CLAW_LUA_MODULE_SCI=y

CONFIG_LOG_MAXIMUM_LEVEL_DEBUG=y
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# USB: Serial JTAG
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
CONFIG_ESP_CONSOLE_SECONDARY_NONE=y
