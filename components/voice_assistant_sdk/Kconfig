menu "Voice Assistant SDK"

config VOICE_ASSISTANT_ENABLE
    bool "Enable voice assistant SDK"
    default y
    help
        Enable the reusable voice assistant component and calendar integration.

config VOICE_ASSISTANT_BACKEND_URL
    string "Voice assistant backend WebSocket URL"
    default ""
    depends on VOICE_ASSISTANT_ENABLE
    help
        URL of the trusted backend that proxies cloud model providers.

config VOICE_ASSISTANT_DEVICE_ID
    string "Voice assistant device id"
    default "esp32-calendar"
    depends on VOICE_ASSISTANT_ENABLE

config VOICE_ASSISTANT_MANUAL_TRIGGER
    bool "Enable manual listen trigger"
    default y
    depends on VOICE_ASSISTANT_ENABLE

config VOICE_ASSISTANT_WAKE_WORD
    bool "Enable local wake word"
    default n
    depends on VOICE_ASSISTANT_ENABLE
    help
        Enable the wake-word listening path. A concrete local recognizer still
        needs to be selected below, or a backend must handle recognition.

config VOICE_ASSISTANT_WAVESHARE_CODEC_PORT
    bool "Enable Waveshare ES7210/ES8311 audio port"
    default n
    depends on VOICE_ASSISTANT_ENABLE
    help
        Build the Waveshare ESP32-S3-RLCD-4.2 codec port using the vendored
        codec_board implementation. This requires the esp_codec_dev component.

config VOICE_ASSISTANT_ESP_SR_LOCAL_RECOGNIZER
    bool "Enable ESP-SR local wake and command recognizer"
    default n
    depends on VOICE_ASSISTANT_ENABLE && VOICE_ASSISTANT_WAKE_WORD
    help
        Build an offline ESP-SR MultiNet recognizer. This supports wake phrase
        plus a finite command set, not arbitrary dictation ASR. It requires the
        esp-sr component and compatible model partition/assets.

config VOICE_ASSISTANT_WAKE_PHRASE_PINYIN
    string "Wake phrase pinyin"
    default "xiao wang xiao wang"
    depends on VOICE_ASSISTANT_ESP_SR_LOCAL_RECOGNIZER

config VOICE_ASSISTANT_WAKE_PHRASE_TEXT
    string "Wake phrase display text"
    default "小王小王"
    depends on VOICE_ASSISTANT_ESP_SR_LOCAL_RECOGNIZER

config VOICE_ASSISTANT_DEFAULT_VOLUME
    int "Default speaker volume"
    default 70
    range 0 100
    depends on VOICE_ASSISTANT_ENABLE

endmenu
